# Copy to .env and fill real values.
TELOXIDE_TOKEN=your_telegram_bot_token
DATABASE_URL=sqlite://shop.db
WEBHOOK_SECRET=change_this_webhook_secret
PORT=8080
LOG_LEVEL=info
ADMIN_JWT_SECRET=change_this_to_at_least_32_random_chars
ADMIN_SETUP_CODE=change_this_setup_code
ADMIN_COOKIE_SECURE=false
RESERVE_TTL_MINUTES=5
# Optional. Usually set from Admin -> Cau hinh Bot -> Admin Telegram.
# Comma/newline-separated Telegram user IDs allowed to send sticker/GIF and receive file_id.
TELEGRAM_ICON_ADMIN_IDS=

# USDT/Binance Pay/BEP20 credentials are optional and should normally be set
# in Admin -> Cau hinh. Leave them out of .env unless this bot needs fixed
# environment defaults for a fresh install.
